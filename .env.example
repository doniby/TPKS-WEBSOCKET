# Database Configuration
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=10.130.0.201
DB_PORT=1521
DB_SID=tos

# Oracle Client Path
# - Local development: set to your local instant client path
#   ORACLE_CLIENT_PATH=D:\TPKS\instantclient21\instantclient_21_19
# - Docker: automatically set to /opt/oracle/instantclient (no need to change)
ORACLE_CLIENT_PATH=

# Database Connection Pool (tuned for session management)
DB_POOL_MIN=2
DB_POOL_MAX=20

# Server Configuration
PORT=3000
NODE_ENV=production

# Logging (debug, info, warn, error) - default: warn in production, debug in development
LOG_LEVEL=warn

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_KEY=your-api-key-for-websocket-clients
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Admin Credentials (Single Account for Admin UI)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# Rate Limiting
RATE_LIMIT_POINTS=10
RATE_LIMIT_DURATION=1

# Connection Limits
MAX_CONNECTIONS=100

# MQTT Bridge
# Use ws://.../mqtt for MQTT over WebSocket
# Use mqtt://host:port for raw TCP MQTT
MQTT_URL=ws://10.130.0.240:49002/mqtt
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_TOPIC_FILTER=#
